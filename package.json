    "prop-types": "^15.8.1",
    "react-test-renderer": "^18.3.1",
    "sass": "^1.83.0"
  },
  "jest": {
    "watchPathIgnorePatterns": [
      "<rootDir>/node_modules/",
      "<rootDir>/.git/"
    ],
